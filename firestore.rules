rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is accessing their own terminal data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /terminals/{userId} {
      // Allow access to own terminal data or the public shared terminal
      allow read, write: if isOwner(userId) || userId == 'shared-terminal';
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || userId == 'shared-terminal';
      }
    }
  }
}
